// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  // Platform-level: manages Organizations themselves (create/(de)activate,
  // assign first ADMIN). Never a member of any organization
  // (organizationId is null for this role only) and never granted access
  // to any organization's own data — see docs/architecture/MULTI_TENANCY.md.
  PLATFORM_ADMIN
  ADMIN
  STAFF
  VIEWER
}

// Tenant boundary. One pharmacist chamber ("Eczacı Odası") per row. Bilecik
// is created as ordinary seed/fixture data, never referenced by name in
// application logic — see docs/architecture/MULTI_TENANCY.md.
model Organization {
  id        String   @id @default(cuid())
  name      String
  province  String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                     User[]
  regions                   Region[]
  auditLogs                 AuditLog[]
  historicalImportBatches   HistoricalDutyImportBatch[]
  dutyPlans                 DutyPlan[]
  rotationPools             RotationPool[]
  pharmacyImportBatches     PharmacyImportBatch[]
  dutyGenerationRuns        DutyGenerationRun[]
  dutyDraftPreviews         DutyDraftPreview[]

  @@index([isActive])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(VIEWER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Null only for PLATFORM_ADMIN — every ordinary (ADMIN/STAFF/VIEWER)
  // user belongs to exactly one organization.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  auditLogs                AuditLog[]
  sessions                 Session[]
  historicalImportBatches  HistoricalDutyImportBatch[]
  dutyBalanceAdjustments   DutyBalanceAdjustment[]
  reviewedDutyRequests     DutyRequest[]
  pharmacyImportBatches    PharmacyImportBatch[]
  approvedGenerationRuns   DutyGenerationRun[] @relation("ApprovedGenerationRuns")
  publishedGenerationRuns  DutyGenerationRun[] @relation("PublishedGenerationRuns")
  dutyDraftPreviews        DutyDraftPreview[]

  @@index([organizationId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Region {
  id             String   @id @default(cuid())
  name           String
  district       String
  dailyDutyCount Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  pharmacies            Pharmacy[]
  dutyRule              DutyRule?
  dutySchedules         DutySchedule[]
  historicalDutyRecords HistoricalDutyRecord[]
  dutyRequests          DutyRequest[]
  pharmacyImportRows    PharmacyImportRow[]
  pharmacyImportRegionCandidates PharmacyImportRegionCandidate[]
  dutyPlans             DutyPlan[]
  rotationPools         RotationPool[]
  dutyGenerationRuns    DutyGenerationRun[]
  dutyDraftPreviews     DutyDraftPreview[]

  // Region names may repeat across organizations, but not within one.
  @@unique([organizationId, name])
  @@index([organizationId])
}

model Pharmacy {
  id             String   @id @default(cuid())
  name           String
  // Türkçe'ye duyarlı normalizasyon (src/lib/historical/normalize.ts'teki
  // normalizeText ile aynı algoritma) — organizasyon+bölge içinde eczane
  // kimliğinin DB seviyesinde tekilliğini sağlar; kullanıcıya hiçbir zaman
  // gösterilmez.
  normalizedName String
  pharmacistName String
  phone          String
  address        String
  city           String
  district       String
  mapUrl         String?
  // Herkese açık nöbet talep formu (/eczane-talep/[token]) için
  // tahmin edilemez, eczaneye özel bağlantı anahtarı.
  requestToken   String?  @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Restrict)

  unavailabilities       Unavailability[]
  dutyAssignments        DutyAssignment[]
  historicalDutyRecords  HistoricalDutyRecord[]
  dutyBalanceAdjustments DutyBalanceAdjustment[]
  dutyRequests           DutyRequest[]
  rotationPoolMemberships RotationPoolMembership[]

  // Pharmacy identity is unique within a region (and therefore within an
  // organization, since a Region belongs to exactly one organization) —
  // never globally. Identical names may exist across organizations.
  @@unique([regionId, normalizedName])
  @@index([regionId])
  @@index([isActive])
}

model DutyRule {
  id                     String   @id @default(cuid())
  minDaysBetweenDuties   Int      @default(1)
  weekdayWeight          Float    @default(1)
  saturdayWeight         Float    @default(1.25)
  sundayWeight           Float    @default(1.5)
  officialHolidayWeight  Float    @default(2)
  religiousHolidayWeight Float    @default(2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  regionId String @unique
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
}

enum HolidayType {
  OFFICIAL
  RELIGIOUS
  OTHER
}

model Holiday {
  id        String      @id @default(cuid())
  name      String
  date      DateTime
  type      HolidayType
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([date, type])
}

model Unavailability {
  id        String   @id @default(cuid())
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId])
}

enum DutyScheduleStatus {
  DRAFT
  // Duty Rules V2 Phase 9: an intermediate human-reviewed checkpoint
  // between a persisted DRAFT (Phase 8) and PUBLISHED. Only ever set by
  // approve-generated-draft.ts, and only for schedules that carry a
  // DutyGenerationRun (Phase 8-generated). V1-generated schedules go
  // straight from DRAFT to PUBLISHED, exactly as before — this status is
  // never produced by any V1 code path.
  APPROVED
  PUBLISHED
}

model DutySchedule {
  id        String             @id @default(cuid())
  month     Int
  year      Int
  status    DutyScheduleStatus @default(DRAFT)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Restrict)

  // Duty Rules V2 (additive, nullable): the plan version that generated
  // this schedule. NULL = generated by the V1 single-rule engine. Restrict
  // so a version referenced by any committed schedule can never be
  // deleted — historical schedules must stay interpretable. See
  // docs/architecture/DUTY_RULES_V2_CORE_SCHEMA.md.
  planVersionId String?
  planVersion   DutyPlanVersion? @relation(fields: [planVersionId], references: [id], onDelete: Restrict)

  assignments DutyAssignment[]
  warnings    DutyScheduleWarning[]
  // Duty Rules V2 Phase 8 (additive, nullable relation): at most one
  // atomic-commit provenance record, present only for schedules created
  // via commit-complete-draft.ts. NULL/absent for every V1-generated or
  // pre-Phase-8 schedule.
  generationRun DutyGenerationRun?

  @@unique([year, month, regionId])
  @@index([regionId])
  @@index([status])
  @@index([planVersionId])
}

model DutyAssignment {
  id        String   @id @default(cuid())
  date      DateTime
  weight    Float    @default(1)
  note      String?
  isManual  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dutyScheduleId String
  dutySchedule   DutySchedule @relation(fields: [dutyScheduleId], references: [id], onDelete: Cascade)

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Restrict)

  // Duty Rules V2 (additive, nullable): which shift this assignment
  // covers (NULL = legacy V1 whole-day assignment) and an opaque slot
  // identifier for future engine explanations. V1 code never writes
  // these. shiftDefinition is Restrict so a shift referenced by any
  // assignment can never be deleted.
  shiftDefinitionId String?
  shiftDefinition   ShiftDefinition? @relation(fields: [shiftDefinitionId], references: [id], onDelete: Restrict)
  slotKey           String?

  // Duty Rules V2 Phase 8 (additive, nullable): assignment provenance
  // for rows created by commit-complete-draft.ts, restating facts
  // Phase 6/7 already computed (never re-derived here). NULL for every
  // V1 row and for any V2 row created outside the Phase 8 commit
  // service — see docs/architecture/DUTY_RULES_V2_ATOMIC_DRAFT_PERSISTENCE.md.
  // `weight` above (existing column) already carries what Phase 7 calls
  // dutyWeight, and `shiftDefinitionId`/`slotKey` above (existing
  // columns) already carry Phase 7's shiftId/slotKey — none are
  // duplicated here.
  draftAssignmentKey   String?
  membershipId         String?
  membership           RotationPoolMembership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  selectionOrdinal     Int?
  origin               AssignmentOrigin?
  strategyId           String?
  strategyType         String?
  fallbackUsed         Boolean?
  selectedRank         Int?
  decisiveCriterion    String?

  generationRunId String?
  generationRun   DutyGenerationRun? @relation(fields: [generationRunId], references: [id], onDelete: Cascade)

  auditLogs AuditLog[]

  // Uniqueness lives in TWO PostgreSQL partial unique indexes created by
  // raw SQL in the duty_rules_v2_core migration (Prisma cannot express
  // partial indexes):
  //   - legacy rows (shiftDefinitionId IS NULL): unique per
  //     (dutyScheduleId, pharmacyId, date) — the exact V1 guarantee,
  //     unchanged (the same-day concurrent manual-edit race described in
  //     the original comment is still caught at the DB level).
  //   - V2 rows (shiftDefinitionId IS NOT NULL): unique per
  //     (dutyScheduleId, pharmacyId, date, shiftDefinitionId) — the same
  //     pharmacy MAY hold two DIFFERENT shifts on one date (a future
  //     configurable SHIFT_MUTUAL_EXCLUSION rule governs that, not the
  //     database).
  // A plain composite unique containing nullable shiftDefinitionId would
  // NOT work: PostgreSQL treats NULLs as distinct, silently disabling
  // the legacy guarantee.
  //
  // The two Phase 8 composite uniques below are scoped BY generationRunId
  // (also nullable) for the identical reason: PostgreSQL never enforces
  // uniqueness across rows where any indexed column is NULL, so V1 rows
  // and any row outside a Phase 8 commit (generationRunId NULL) are
  // structurally exempt and can never collide with each other or with a
  // real run's rows.
  //   - no duplicate draftAssignmentKey inside one generation run (also
  //     rules out inserting the exact same Phase 7 assignment twice).
  //   - no duplicate selectionOrdinal inside one persisted slot of one
  //     generation run.
  @@unique([generationRunId, draftAssignmentKey])
  @@unique([generationRunId, slotKey, selectionOrdinal])
  @@index([dutyScheduleId, pharmacyId, date])
  @@index([shiftDefinitionId])
  @@index([dutyScheduleId])
  @@index([pharmacyId])
  @@index([date])
  @@index([generationRunId])
  @@index([membershipId])
}

enum AssignmentOrigin {
  STRICT
  RELAXED
}

model DutyScheduleWarning {
  id        String   @id @default(cuid())
  date      DateTime
  message   String
  createdAt DateTime @default(now())

  scheduleId String
  schedule   DutySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
}

enum DutyGenerationRunStatus {
  // Written by commit-complete-draft.ts (Phase 8) — the schedule is
  // DRAFT.
  COMMITTED
  // Duty Rules V2 Phase 9: written by approve-generated-draft.ts. Mirrors
  // DutySchedule.status === APPROVED for this run's own schedule.
  APPROVED
  // Duty Rules V2 Phase 9: written by publish-approved-schedule.ts.
  // Mirrors DutySchedule.status === PUBLISHED.
  PUBLISHED
}

// Duty Rules V2 — Phase 8: one immutable, append-only provenance record
// of a single successful atomic commit of a Phase 7 CompleteDraftSchedule
// into a DRAFT DutySchedule (see commit-complete-draft.ts and
// docs/architecture/DUTY_RULES_V2_ATOMIC_DRAFT_PERSISTENCE.md). Never
// updated after creation. completeDraftFingerprint is globally unique —
// that uniqueness constraint IS the idempotency key: two commit attempts
// carrying byte-identical CompleteDraftSchedule content can never create
// two rows (the second resolves as IDEMPOTENT_REPLAY against the first).
//
// dutyScheduleId is a 1:1 (@unique) Cascade relation: one generation run
// belongs to exactly one persisted schedule, and deleting that schedule
// (the existing deleteDutyScheduleAction path) cleans up its generation
// run automatically, exactly like DutyScheduleWarning above.
// organizationId/regionId/planId/planVersionId are stored redundantly
// (not solely derivable through the dutySchedule relation) so tenant-
// scoped audit/history queries never require a join back through
// DutySchedule -> Region -> Organization, and so tenant mismatches are
// checkable directly against this row.
//
// Stores NO executable content, no environment values, no secrets —
// only hashes/counts/ids and `manifest`, which is the already-computed,
// plain descriptive DraftGenerationManifest JSON document (never
// interpreted as code, never containing a raw Prisma error).
model DutyGenerationRun {
  id        String                  @id @default(cuid())
  status    DutyGenerationRunStatus @default(COMMITTED)
  createdAt DateTime                @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Restrict)

  planId String
  plan   DutyPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  planVersionId String
  planVersion   DutyPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Restrict)

  dutyScheduleId String       @unique
  dutySchedule   DutySchedule @relation(fields: [dutyScheduleId], references: [id], onDelete: Cascade)

  generationMode String
  periodStart    DateTime
  periodEnd      DateTime

  // Phase 2-6 provenance, copied verbatim from
  // CompleteDraftSchedule.provenance (EngineRunProvenance).
  configurationFingerprint String
  runtimeInputHash         String
  ruleSetFingerprint       String
  strategySetFingerprint   String
  // Phase 4-6 result fingerprint this draft was assembled from
  // (CompleteDraftSchedule.manifest.sourceResultFingerprint).
  upstreamResultFingerprint String
  // Deterministic aggregate over the distinct per-assignment
  // sourceProvenance.membershipSnapshotHash values present in the draft
  // (sha256Canonical of the sorted, deduplicated set) — CompleteDraftSchedule
  // has no single top-level membership snapshot hash because a draft can
  // span more than one rotation pool. See commit-complete-draft.ts.
  membershipSnapshotHash String
  // Deterministic aggregate over every assignment's own restated Phase 6
  // facts (slotKey, candidateKey, selectionOrdinal, provisionalRank,
  // origin, strategyId, strategyType), sha256Canonical-hashed — again
  // computed here because CompleteDraftSchedule has no single top-level
  // field for it. See commit-complete-draft.ts.
  provisionalSelectionFingerprint String
  // CompleteDraftSchedule.completeDraftFingerprint verbatim — the
  // idempotency key (see @unique below).
  completeDraftFingerprint String @unique

  // CompleteDraftSchedule.engineVersion / .selectionEngineVersion,
  // verbatim.
  engineVersion          Int
  selectionEngineVersion Int
  // Phase 8's OWN contract version: which version of the Phase 7
  // CompleteDraftSchedule SHAPE this commit service validated against.
  // NOT a Phase 7 field — Phase 7 versions itself via engineVersion/
  // selectionEngineVersion above, both persisted verbatim. See
  // DRAFT_ENGINE_VERSION in commit-complete-draft.ts.
  draftEngineVersion Int

  // The already-computed DraftGenerationManifest, stored verbatim as
  // plain descriptive JSON (never interpreted as code) so the full
  // generation summary (counts, blockingDiagnosticCodes, assignmentKeys,
  // etc.) survives independent of the DutyAssignment rows below.
  manifest Json

  // Duty Rules V2 Phase 9 (additive, nullable): set once by
  // approve-generated-draft.ts. Mirrors DutyRequest's reviewedById/
  // reviewedAt naming convention.
  approvedById String?
  approvedBy   User?     @relation("ApprovedGenerationRuns", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  // Duty Rules V2 Phase 9 (additive, nullable): a snapshot, captured at
  // approval time, of every RotationState row publication will touch —
  // [{ rotationStateId, lockVersion }, ...]. This is "the state expected
  // by the generation input" the optimistic-lock check at publication
  // time compares against: if any listed row's CURRENT lockVersion has
  // since changed, publication is rejected with ROTATION_STATE_CONFLICT
  // rather than silently overwriting a change made after this draft was
  // approved. Plain descriptive JSON, never interpreted as code. See
  // publish-approved-schedule.ts.
  rotationStateSnapshot Json?

  // Duty Rules V2 Phase 9 (additive, nullable): set once by
  // publish-approved-schedule.ts, in the same transaction that advances
  // RotationState and sets DutySchedule.status = PUBLISHED.
  publishedById String?
  publishedBy   User?     @relation("PublishedGenerationRuns", fields: [publishedById], references: [id])
  publishedAt   DateTime?

  assignments DutyAssignment[]

  @@index([organizationId, regionId])
  @@index([planVersionId])
  @@index([dutyScheduleId])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  entity    String
  entityId  String
  before    String?
  after     String?
  createdAt DateTime    @default(now())

  // Explicit (not derived through userId) so audit-log queries stay a
  // single indexed WHERE, and so the log remains readable even if a user
  // is later reassigned — an audit trail must reflect the tenant the
  // action happened in, not the actor's current tenant.
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  userId String
  user   User @relation(fields: [userId], references: [id])

  dutyAssignmentId String?
  dutyAssignment   DutyAssignment? @relation(fields: [dutyAssignmentId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum HistoricalMatchStatus {
  MATCHED
  UNMATCHED
  IGNORED
}

model HistoricalDutyImportBatch {
  id             String   @id @default(cuid())
  fileName       String
  rowCount       Int      @default(0)
  matchedCount   Int      @default(0)
  unmatchedCount Int      @default(0)
  warningCount   Int      @default(0)
  note           String?
  // Kabul edilen satırların içeriğinden üretilen deterministik SHA-256
  // parmak izi (bkz. computeImportFingerprint). Aynı içeriğin eşzamanlı
  // iki kez onaylanmasını DB seviyesinde engeller — `note` insan tarafından
  // okunabilir bir alan olarak kalır, tekilliğe dayanak değildir.
  fingerprint    String?  @unique
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  importedById String?
  importedBy   User?   @relation(fields: [importedById], references: [id])

  records HistoricalDutyRecord[]

  @@index([organizationId])
}

model HistoricalDutyRecord {
  id              String                @id @default(cuid())
  rowNumber       Int
  dutyDate        DateTime
  rawPharmacyName String
  rawRegionName   String?
  rawDutyType     String?
  rawPhone        String?
  rawAddress      String?
  rawNote         String?
  dutyType        String
  weight          Float                 @default(1)
  matchStatus     HistoricalMatchStatus @default(UNMATCHED)
  warningMessage  String?
  createdAt       DateTime              @default(now())

  batchId String
  batch   HistoricalDutyImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  pharmacyId String?
  pharmacy   Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([pharmacyId])
  @@index([regionId])
  @@index([dutyDate])
  @@index([batchId])
  @@index([matchStatus])
}

model DutyBalanceAdjustment {
  id        String   @id @default(cuid())
  points    Float
  reason    String
  createdAt DateTime @default(now())

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  @@index([pharmacyId])
}

enum DutyRequestType {
  CANNOT_DUTY
  PREFER_DUTY
  SWAP_REQUEST
  EMERGENCY_EXCUSE
}

enum DutyRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  LATE
}

enum DutyRequestSource {
  ADMIN_ENTRY
  PUBLIC_LINK
  IMPORT
}

model DutyRequest {
  id          String            @id @default(cuid())
  requestType DutyRequestType
  startDate   DateTime
  endDate     DateTime
  explanation String
  status      DutyRequestStatus @default(PENDING)
  source      DutyRequestSource @default(ADMIN_ENTRY)
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User?   @relation(fields: [reviewedById], references: [id])

  // PUBLIC_LINK talepleri için pharmacyId+requestType+startDate+endDate+
  // explanation+source üzerinden üretilen deterministik anahtar; yalnızca
  // talep PENDING/LATE iken doludur. Eşzamanlı çift gönderimi DB
  // seviyesinde engeller. reviewDutyRequestAction talep incelendiğinde
  // (PENDING/LATE'den çıktığında) null'a çevirir — tekil nullable kısıt
  // birden fazla null'a izin verdiği için, kapanmış bir talep aynı içerikle
  // yeniden gönderilecek gelecekteki bir talebi engellemez.
  dedupKey String? @unique

  @@index([pharmacyId])
  @@index([regionId])
  @@index([status])
  @@index([requestType])
  @@index([startDate])
  @@index([endDate])
}

// Login rate-limit counter (pre-pilot Step 2 — see
// docs/security/21-login-rate-limit-proxy-validation.md). One row per
// (bucketType, bucketKey) pair. `bucketKey` is always a SHA-256 digest
// (src/lib/security/hash-identifier.ts) — never a raw email or IP
// address. `bucketType` is "NETWORK" or "ACCOUNT" (kept as a plain
// String rather than an enum since it is never surfaced in UI and this
// keeps the table trivial to extend if a third dimension is ever added).
model LoginAttempt {
  id           String    @id @default(cuid())
  bucketType   String
  bucketKey    String
  failureCount Int       @default(0)
  windowStart  DateTime
  blockedUntil DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([bucketType, bucketKey])
  @@index([blockedUntil])
  @@index([windowStart])
}

enum PharmacyImportBatchStatus {
  PREVIEWED
  IMPORTED
  EXPIRED
}

enum PharmacyImportRowStatus {
  READY
  INVALID
  DUPLICATE_IN_FILE
  ALREADY_EXISTS
  UNKNOWN_REGION
  // Region discovery: the row's region candidate still needs an ADMIN
  // decision (approval / inactive-region acknowledgment / suggestion
  // confirmation / manual assignment)…
  REGION_PENDING
  // …or the ADMIN excluded the row's candidate: skipped, never imported,
  // never blocking.
  EXCLUDED
}

// Where a region candidate's text came from — an explicit Bölge cell, an
// İlçe cell, a purely structural address-derived suggestion, or a manual
// entry the ADMIN typed during preview. Never an external service and
// never a hardcoded province/district list.
enum PharmacyImportCandidateSource {
  BOLGE_COLUMN
  ILCE_COLUMN
  ADDRESS_SUGGESTION
  MANUAL
}

enum PharmacyImportCandidateStatus {
  MATCHED_EXISTING_ACTIVE
  MATCHED_EXISTING_INACTIVE
  NEW_REGION_CANDIDATE
  ADDRESS_SUGGESTION
  AMBIGUOUS
  UNRESOLVED
  EXCLUDED_BY_ADMIN
}

// Generic (province-agnostic) Pharmacy Excel Import — the preview step
// persists here (not in process memory, which is not multi-instance-safe
// on Railway) rather than writing Pharmacy rows. No workbook binary, no
// formulas, no unnecessary source-cell data is ever stored — only the
// already-normalized/validated fields needed to render the preview and
// perform the final import. See docs/features/PHARMACY_EXCEL_IMPORT.md.
model PharmacyImportBatch {
  id               String                    @id @default(cuid())
  status           PharmacyImportBatchStatus @default(PREVIEWED)
  sanitizedFileName String
  fileSize         Int
  totalRows        Int
  readyRows        Int
  invalidRows      Int
  expiresAt        DateTime
  consumedAt       DateTime?
  createdAt        DateTime                  @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  rows             PharmacyImportRow[]
  regionCandidates PharmacyImportRegionCandidate[]

  @@index([organizationId, status])
  @@index([expiresAt])
}

// One aggregated region candidate per unique (Turkish-normalized) region
// value discovered in an uploaded workbook, plus manual candidates the
// ADMIN defines during preview. Tenant ownership derives exclusively
// through the parent batch's organizationId — this table never stores an
// organizationId of its own, so there is nothing client-suppliable to
// tamper with. No Region row is written from here before the final
// all-or-nothing import transaction. See
// docs/features/AUTOMATIC_REGION_DISCOVERY.md.
model PharmacyImportRegionCandidate {
  id                    String                        @id @default(cuid())
  sourceValue           String
  normalizedSourceValue String
  sourceType            PharmacyImportCandidateSource
  status                PharmacyImportCandidateStatus
  proposedName          String
  normalizedProposedName String
  proposedCity          String
  proposedDistrict      String
  proposedIsActive      Boolean                       @default(true)
  // Set when the ADMIN explicitly approved this candidate (new-region
  // approval, address-suggestion acceptance, or the keep-inactive/
  // reactivate decision for an inactive match). Never set automatically.
  approvedAt            DateTime?
  // Only meaningful for MATCHED_EXISTING_INACTIVE: reactivate the region
  // inside the final import transaction (audited) instead of importing
  // into it while it stays inactive. Never true without approvedAt.
  reactivateOnImport    Boolean                       @default(false)
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt

  batchId String
  batch   PharmacyImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  matchedRegionId String?
  matchedRegion   Region? @relation(fields: [matchedRegionId], references: [id], onDelete: SetNull)

  rows PharmacyImportRow[]

  // One candidate per normalized source value within a batch — repeated
  // workbook values aggregate instead of duplicating.
  @@unique([batchId, normalizedSourceValue])
  @@index([batchId])
  @@index([matchedRegionId])
}

model PharmacyImportRow {
  id                    String                   @id @default(cuid())
  rowNumber             Int
  pharmacyName          String
  normalizedPharmacyName String
  pharmacistName        String?
  phone                 String?
  isActive              Boolean                  @default(true)
  status                PharmacyImportRowStatus
  safeErrorCode         String?
  createdAt             DateTime                 @default(now())

  batchId String
  batch   PharmacyImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  // Region-discovery columns: the raw (trimmed) region/district source
  // text as uploaded, the validated optional address, and the candidate
  // this row resolved to. Deleting a candidate detaches its rows
  // (SetNull) — they fall back to unresolved, never dangle.
  sourceRegionText   String?
  sourceDistrictText String?
  address            String?
  candidateId        String?
  candidate          PharmacyImportRegionCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([regionId])
  @@index([candidateId])
}

// ---------------------------------------------------------------------------
// Duty Rules V2 — core schema (Phase 1, additive only). No engine, no UI,
// no lifecycle actions exist yet; V1 (DutyRule + generate-duty-schedule)
// remains the only production behavior. See
// docs/architecture/DUTY_RULES_V2_CORE_SCHEMA.md. Nothing here encodes any
// specific chamber, city, province, or district — every row is
// organization-configured data.
// ---------------------------------------------------------------------------

enum DutyPlanVersionStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  ACTIVE
  RETIRED
  ARCHIVED
}

enum DutyDayType {
  WEEKDAY
  SATURDAY
  SUNDAY
  OFFICIAL_HOLIDAY
  RELIGIOUS_HOLIDAY
  HOLIDAY_EVE
}

enum RotationStrategy {
  SEQUENTIAL
  FAIRNESS_SCORE
  WEIGHTED
  MANUAL_ORDER
}

// The named container for how one duty region is scheduled. A region MAY
// have multiple plans (drafts, retired experiments) — deliberately NO
// unique constraint on regionId. Only one plan VERSION may be ACTIVE for
// a region over an overlapping effective period; that exclusivity is a
// documented service-layer requirement for the future activation action
// (advisory lock + range check), NOT a simple unique constraint, because
// date-range overlap cannot be expressed as a Prisma unique.
//
// Region currently doubles as the V2 "DutyRegion" (compatibility
// decision). AdministrativeDistrict and DutyRegion may be separated
// later; nothing here prevents that: DutyPlan references Region only by
// id, and no V2 table copies Region.district.
model DutyPlan {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Restrict)

  versions DutyPlanVersion[]
  dutyGenerationRuns DutyGenerationRun[]

  @@index([organizationId])
  @@index([regionId])
}

// The immutable configuration boundary: one complete versioned duty
// configuration for a plan. Once ACTIVE (activatedAt set), a version's
// children (day-type rules, shifts, slots) are edit-frozen — enforced by
// the future lifecycle service layer, not the database. Historical
// schedules reference the version that generated them (Restrict), so an
// ever-used version can never be deleted. Tenant ownership derives
// exclusively through DutyPlan.organizationId.
model DutyPlanVersion {
  id            String                @id @default(cuid())
  versionNumber Int
  status        DutyPlanVersionStatus @default(DRAFT)
  validFrom     DateTime
  validTo       DateTime?
  approvedAt    DateTime?
  activatedAt   DateTime?
  retiredAt     DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  planId String
  plan   DutyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  dayTypeRules       DayTypeRule[]
  shiftDefinitions   ShiftDefinition[]
  dutySchedules      DutySchedule[]
  dutyGenerationRuns DutyGenerationRun[]
  dutyDraftPreviews  DutyDraftPreview[]

  @@unique([planId, versionNumber])
  @@index([planId, status])
  @@index([validFrom])
}

// Per (version, day type): whether that day type is served and any
// day-type-level notes. customDayCategory is the forward-compatible
// extensibility point for repeated local categories a chamber defines
// later (e.g. a recurring local market day) WITHOUT changing the enum —
// rows with a category coexist with the plain enum row. Uniqueness lives
// in two partial unique indexes (raw SQL, see the core migration):
// unique (planVersionId, dayType) WHERE customDayCategory IS NULL, and
// unique (planVersionId, dayType, customDayCategory) WHERE NOT NULL.
// Custom-calendar EVALUATION is deliberately not implemented yet.
model DayTypeRule {
  id                String      @id @default(cuid())
  dayType           DutyDayType
  isServed          Boolean     @default(true)
  customDayCategory String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  planVersionId String
  planVersion   DutyPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  slotRequirements SlotRequirement[]

  @@index([planVersionId, dayType])
}

// A shift shape OWNED BY ITS PLAN VERSION (never organization-global):
// the same shift name may mean different hours in different regions or
// versions, and historical versions must preserve their exact shift
// definitions. Times are minutes-from-midnight; spansMidnight marks
// shifts ending on the next day (e.g. 20:00 -> 08:00). Referenced by
// DutyAssignment (Restrict), so a shift ever used by a committed
// schedule can never be deleted even though draft versions cascade.
model ShiftDefinition {
  id            String  @id @default(cuid())
  name          String
  startMinute   Int
  endMinute     Int
  spansMidnight Boolean @default(false)
  defaultWeight Float   @default(1)
  sortOrder     Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  planVersionId String
  planVersion   DutyPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  slotRequirements SlotRequirement[]
  dutyAssignments  DutyAssignment[]

  @@unique([planVersionId, name])
  @@index([planVersionId, sortOrder])
}

// "On this day type, this shift needs N pharmacies (optionally from this
// rotation pool)." Multiple slot requirements per day type express
// multi-shift days and split quotas (Model B/C shapes) without any
// hardcoded template. rotationPoolId NULL = the future engine's default
// pool semantics. sortOrder gives deterministic slot expansion order.
// ServiceArea references are deliberately deferred to a later phase.
model SlotRequirement {
  id            String  @id @default(cuid())
  name          String?
  requiredCount Int
  sortOrder     Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dayTypeRuleId String
  dayTypeRule   DayTypeRule @relation(fields: [dayTypeRuleId], references: [id], onDelete: Cascade)

  shiftDefinitionId String
  shiftDefinition   ShiftDefinition @relation(fields: [shiftDefinitionId], references: [id], onDelete: Cascade)

  rotationPoolId String?
  rotationPool   RotationPool? @relation(fields: [rotationPoolId], references: [id], onDelete: Restrict)

  @@index([dayTypeRuleId, sortOrder])
  @@index([shiftDefinitionId])
  @@index([rotationPoolId])
}

// A named eligible-pharmacy pool with an ordering strategy. Owned by the
// organization; optionally scoped to one region (NULL = organization-
// wide pool, shareable across regions). Pool names are unique per
// organization — identical names in different organizations are allowed
// and cross-tenant-tested.
model RotationPool {
  id        String           @id @default(cuid())
  name      String
  strategy  RotationStrategy @default(SEQUENTIAL)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id], onDelete: Restrict)

  memberships      RotationPoolMembership[]
  rotationStates   RotationState[]
  slotRequirements SlotRequirement[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([regionId])
}

// TEMPORAL pool membership: a pharmacy's period inside a pool. A
// transfer between pools NEVER overwrites history — it closes the old
// row (leftAt) and opens a new one in the target pool. "Active
// membership as of date D" = joinedAt <= D AND (leftAt IS NULL OR
// leftAt > D). sortIndex orders MANUAL_ORDER pools. Pharmacy is Restrict
// so temporal history is never silently lost with a pharmacy delete.
model RotationPoolMembership {
  id        String    @id @default(cuid())
  joinedAt  DateTime
  leftAt    DateTime?
  sortIndex Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  poolId String
  pool   RotationPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Restrict)

  rotationStatesAsCursor RotationState[]
  dutyAssignments        DutyAssignment[]

  @@unique([poolId, pharmacyId, joinedAt])
  @@index([poolId, leftAt])
  @@index([pharmacyId])
}

// Persistent rotation progression per (pool, day-type scope) — Model A's
// "whose turn is it" that survives across months/quarters. dayTypeScope
// is a string ("ALL", a DutyDayType name, or a future custom category)
// rather than the enum so scopes can extend without migrations.
// carriedForward is a SMALL validated JSON list (see
// src/lib/duty-rules-v2/rotation-state.ts) of skipped memberships owed a
// turn — deliberately minimal, not a generic blob. lockVersion enables
// optimistic concurrency, used by Duty Rules V2 Phase 9's
// publish-approved-schedule.ts — the ONLY writer of this table's
// currentRound/lastServedMembershipId/carriedForward/lockVersion fields.
// See docs/architecture/DUTY_RULES_V2_APPROVAL_PUBLICATION.md.
model RotationState {
  id                     String   @id @default(cuid())
  dayTypeScope           String   @default("ALL")
  currentRound           Int      @default(0)
  carriedForward         Json     @default("[]")
  lockVersion            Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  poolId String
  pool   RotationPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  // The last-served cursor: SetNull keeps state meaningful (round and
  // carry-forward survive) even if the exact membership row disappears.
  lastServedMembershipId String?
  lastServedMembership   RotationPoolMembership? @relation(fields: [lastServedMembershipId], references: [id], onDelete: SetNull)

  @@unique([poolId, dayTypeScope])
  @@index([poolId])
}

// ---------------------------------------------------------------------------
// Duty Rules V2 — Phase 10: Admin UI integration (additive only).
// ---------------------------------------------------------------------------

// Mirrors src/lib/duty-rules-v2/draft/domain/draft-schedule.ts's
// CompleteDraftStatus TypeScript union — persisted here only so
// DutyDraftPreview.status can be typed, never interpreted by any Phase
// 2-9 engine/persistence code (those modules keep using the plain
// TypeScript union).
enum CompleteDraftStatus {
  COMPLETE
  PARTIAL
  INVALID
}

// Duty Rules V2 — Phase 10: a short-lived, tenant-scoped holder for one
// generated (but not yet committed) Phase 7 CompleteDraftSchedule, so an
// admin can review a rendered preview before persisting it — WITHOUT
// regenerating it and WITHOUT the browser ever needing to round-trip raw
// assignment data. Modeled closely on PharmacyImportBatch above (same
// tenant-scoping + createdBy + expiresAt/consumedAt preview-then-commit
// pattern). `payload` stores the CompleteDraftSchedule verbatim as plain
// descriptive JSON (never interpreted as code, never containing a raw
// Prisma error) — commitV2DraftAction reads it back from THIS row and
// feeds it into commit-complete-draft.ts, so persistence never trusts
// anything the browser itself posts.
model DutyDraftPreview {
  id                       String              @id @default(cuid())
  status                   CompleteDraftStatus
  isCommitEligible         Boolean
  periodStart              DateTime
  periodEnd                DateTime
  assignmentCount          Int
  missingAssignmentCount   Int
  warningCount             Int
  completeDraftFingerprint String
  payload                  Json
  expiresAt                DateTime
  consumedAt               DateTime?
  createdAt                DateTime            @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  planVersionId String
  planVersion   DutyPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  @@index([organizationId, regionId])
  @@index([expiresAt])
}
