// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(VIEWER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs                AuditLog[]
  sessions                 Session[]
  historicalImportBatches  HistoricalDutyImportBatch[]
  dutyBalanceAdjustments   DutyBalanceAdjustment[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Region {
  id             String   @id @default(cuid())
  name           String   @unique
  district       String
  dailyDutyCount Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pharmacies            Pharmacy[]
  dutyRule              DutyRule?
  dutySchedules         DutySchedule[]
  historicalDutyRecords HistoricalDutyRecord[]
}

model Pharmacy {
  id             String   @id @default(cuid())
  name           String
  pharmacistName String
  phone          String
  address        String
  city           String
  district       String
  mapUrl         String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Restrict)

  unavailabilities       Unavailability[]
  dutyAssignments        DutyAssignment[]
  historicalDutyRecords  HistoricalDutyRecord[]
  dutyBalanceAdjustments DutyBalanceAdjustment[]

  @@index([regionId])
  @@index([isActive])
}

model DutyRule {
  id                     String   @id @default(cuid())
  minDaysBetweenDuties   Int      @default(1)
  weekdayWeight          Float    @default(1)
  saturdayWeight         Float    @default(1.25)
  sundayWeight           Float    @default(1.5)
  officialHolidayWeight  Float    @default(2)
  religiousHolidayWeight Float    @default(2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  regionId String @unique
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
}

enum HolidayType {
  OFFICIAL
  RELIGIOUS
  OTHER
}

model Holiday {
  id        String      @id @default(cuid())
  name      String
  date      DateTime
  type      HolidayType
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([date, type])
}

model Unavailability {
  id        String   @id @default(cuid())
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId])
}

enum DutyScheduleStatus {
  DRAFT
  PUBLISHED
}

model DutySchedule {
  id        String             @id @default(cuid())
  month     Int
  year      Int
  status    DutyScheduleStatus @default(DRAFT)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Restrict)

  assignments DutyAssignment[]
  warnings    DutyScheduleWarning[]

  @@unique([year, month, regionId])
  @@index([regionId])
  @@index([status])
}

model DutyAssignment {
  id        String   @id @default(cuid())
  date      DateTime
  weight    Float    @default(1)
  note      String?
  isManual  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dutyScheduleId String
  dutySchedule   DutySchedule @relation(fields: [dutyScheduleId], references: [id], onDelete: Cascade)

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Restrict)

  auditLogs AuditLog[]

  @@index([dutyScheduleId])
  @@index([pharmacyId])
  @@index([date])
}

model DutyScheduleWarning {
  id        String   @id @default(cuid())
  date      DateTime
  message   String
  createdAt DateTime @default(now())

  scheduleId String
  schedule   DutySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  entity    String
  entityId  String
  before    String?
  after     String?
  createdAt DateTime    @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  dutyAssignmentId String?
  dutyAssignment   DutyAssignment? @relation(fields: [dutyAssignmentId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum HistoricalMatchStatus {
  MATCHED
  UNMATCHED
  IGNORED
}

model HistoricalDutyImportBatch {
  id             String   @id @default(cuid())
  fileName       String
  rowCount       Int      @default(0)
  matchedCount   Int      @default(0)
  unmatchedCount Int      @default(0)
  warningCount   Int      @default(0)
  note           String?
  createdAt      DateTime @default(now())

  importedById String?
  importedBy   User?   @relation(fields: [importedById], references: [id])

  records HistoricalDutyRecord[]
}

model HistoricalDutyRecord {
  id              String                @id @default(cuid())
  rowNumber       Int
  dutyDate        DateTime
  rawPharmacyName String
  rawRegionName   String?
  rawDutyType     String?
  rawPhone        String?
  rawAddress      String?
  rawNote         String?
  dutyType        String
  weight          Float                 @default(1)
  matchStatus     HistoricalMatchStatus @default(UNMATCHED)
  warningMessage  String?
  createdAt       DateTime              @default(now())

  batchId String
  batch   HistoricalDutyImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  pharmacyId String?
  pharmacy   Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([pharmacyId])
  @@index([regionId])
  @@index([dutyDate])
  @@index([batchId])
  @@index([matchStatus])
}

model DutyBalanceAdjustment {
  id        String   @id @default(cuid())
  points    Float
  reason    String
  createdAt DateTime @default(now())

  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  @@index([pharmacyId])
}
