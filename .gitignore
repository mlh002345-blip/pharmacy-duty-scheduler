# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# prisma sqlite database
/prisma/*.db
/prisma/*.db-journal

# local PostgreSQL backup/restore rehearsal output (dumps, checksums,
# manifests, rehearsal reports) — never committed; dump files can contain
# real data even though this repo's own tooling only ever prints
# sanitized identifiers
/backups/

# Playwright E2E test output (screenshots/traces on failure)
/test-results/
/playwright-report/
/blob-report/

# Performance-benchmark output (manifests, EXPLAIN ANALYZE JSON,
# measurement reports) — never committed; the concise markdown summaries
# under docs/ are what gets committed instead
/benchmark-output/

# Chaos/DB-resilience test run manifests — never committed; the concise
# markdown summary under docs/ is what gets committed instead
/chaos-output/

# Excel/XLSX file-security test run manifests and generated fixtures
# (some deliberately large/zip-bomb-shaped) — never committed; the
# concise markdown summary under docs/ is what gets committed instead
/file-security-output/
