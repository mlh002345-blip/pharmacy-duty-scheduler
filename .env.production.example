# Hosted demo / gerçek pilot ortamı için örnek değişkenler.
# Gerçek değerleri bu dosyaya YAZMAYIN — bu sadece bir şablondur.
# Ayrıntılı kurulum adımları için bkz. docs/DEPLOYMENT.md

# Hosted/production ortamı PostgreSQL kullanır (bkz. docs/DEPLOYMENT.md →
# "PostgreSQL Hazırlığı"). Bu değeri kendi PostgreSQL bağlantı bilgilerinizle
# değiştirin; gerçek şifreyi asla repoya eklemeyin.
DATABASE_URL="postgresql://KULLANICI:SIFRE@HOST:5432/VERITABANI?schema=public"

NODE_ENV="production"

# Uygulamanın dışa açık, gerçek adresi (mutlak URL üretimi, CORS/güvenlik
# başlıkları vb. için ileride gerekebilir).
APP_URL="https://nobet.ornekoda.org.tr"

# Not: Oturumlar veritabanında saklanan rastgele opak token'lar ile
# doğrulanır, imzalı (JWT) bir mekanizma kullanılmaz — bu yüzden şu an
# bir SESSION_SECRET gerekmiyor (bkz. src/lib/auth/session.ts). Yine de
# ileride eklenebilecek bir imzalama anahtarı için alan ayrılmıştır;
# eklenirse en az 32 byte'lık rastgele, gizli bir değer kullanılmalıdır:
#   openssl rand -hex 32
# SESSION_SECRET="__PRODUCTION_ORTAMINDA_GUCLU_RASTGELE_BIR_DEGERLE_DEGISTIRIN__"

# Demo seed script'i (prisma/seed.ts), veritabanını temizleyip sahte demo
# verisiyle doldurur. Production ortamında YANLIŞLIKLA çalıştırılmasını
# önlemek için varsayılan olarak KAPALIDIR. Sadece geçici bir hosted demo
# ortamında bilinçli olarak açmak isterseniz DEMO_SEED=true ayarlayın ve
# `npm run db:seed` komutunu çalıştırın. Gerçek pilot ortamında bu
# değişkeni HİÇBİR ZAMAN ayarlamayın / true yapmayın.
DEMO_SEED="false"

# İlk yönetici (ADMIN) kullanıcısını oluşturmak için `npm run db:create-admin`
# script'inin kullandığı değişkenler (bkz. scripts/create-admin.ts ve
# docs/DEPLOYMENT.md → "İlk Yönetici Kullanıcısını Oluşturma"). Sadece bu
# script'i çalıştırırken geçici olarak ayarlanmaları yeterlidir; kalıcı
# olarak saklanmalarına gerek yoktur.
ADMIN_NAME="Sistem Yöneticisi"
ADMIN_EMAIL="admin@odaniz.org.tr"
ADMIN_PASSWORD="GUCLU-BIR-SIFRE-BURAYA"

# Giriş (login) oran sınırlama (rate limiting), istemci IP'sini yalnızca
# X-Forwarded-For güvenilirse "ağ" boyutuyla (network dimension) ayırt
# edebilir. Varsayılan olarak KAPALIDIR ve bu depo, Railway'in bu başlığı
# gerçekte nasıl ayarladığını/üzerine yazdığını doğrulayacak hiçbir bilgi
# içermez (bkz. docs/security/21-login-rate-limit-proxy-validation.md).
# Yalnızca docs/testing/LOGIN_RATE_LIMIT_PROXY_TEST.md'deki canlı
# doğrulama adımları GERÇEK production/staging ortamınızda tamamlandıktan
# SONRA "true" yapın. Kapalıyken hesap bazlı (account) sınırlama tam
# olarak çalışmaya devam eder — yalnızca ağ bazlı ayrım kaybolur.
TRUST_PROXY_HEADERS="false"
